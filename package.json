{
  "name": "propdesk",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate --filter=@propdesk/api",
    "db:migrate": "turbo db:migrate --filter=@propdesk/api",
    "db:push": "turbo db:push --filter=@propdesk/api",
    "db:seed": "npm run db:seed --workspace=@propdesk/api"
  },
  "devDependencies": {
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
